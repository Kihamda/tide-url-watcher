<Window
    x:Class="Tide.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tide.App"
    Title="Tide">
    <Grid x:Name="RootGrid" Background="#FAF9F5" IsTabStop="True" KeyDown="RootGrid_KeyDown" Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F1EB" BorderBrush="#E0E4DE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="238" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="18,0,0,0" VerticalAlignment="Center" Orientation="Horizontal" Spacing="9">
                    <Border Width="22" Height="22" CornerRadius="11" Background="#53695D">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Georgia" Foreground="White" Text="T" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" CharacterSpacing="240" FontSize="10" FontWeight="SemiBold" Foreground="#3D4842" Text="TIDE" />
                </StackPanel>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11" Foreground="#7D867F" Text="{x:Bind LastRefreshText, Mode=OneWay}" />
                <Button Grid.Column="2" Margin="0,0,14,0" AutomationProperties.Name="設定" Background="Transparent" BorderThickness="0" Click="Settings_Click" Foreground="#7D867F" Style="{StaticResource TideButtonStyle}" Content="☰" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="238" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="214" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="14,24,14,16" Background="#EFF0EA" BorderBrush="#E0E4DE" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock Margin="9,0,0,7" CharacterSpacing="190" FontSize="9" FontWeight="SemiBold" Foreground="#9DA39E" Text="LIBRARY" />
                        <Button Click="AllStories_Click" Style="{StaticResource SideButtonStyle}">
                            <Grid><TextBlock Text="◉   すべての新着" /><TextBlock HorizontalAlignment="Right" Text="{x:Bind TotalCount, Mode=OneWay}" /></Grid>
                        </Button>
                        <Button Click="UnreadStories_Click" Style="{StaticResource SideButtonStyle}">
                            <Grid><TextBlock Text="✦   未読" /><TextBlock HorizontalAlignment="Right" Text="{x:Bind UnreadCount, Mode=OneWay}" /></Grid>
                        </Button>
                        <Button Click="SavedStories_Click" Style="{StaticResource SideButtonStyle}">
                            <Grid><TextBlock Text="◇   保存済み" /><TextBlock HorizontalAlignment="Right" Text="{x:Bind SavedCount, Mode=OneWay}" /></Grid>
                        </Button>
                        <Button Click="TodayStories_Click" Style="{StaticResource SideButtonStyle}">
                            <Grid><TextBlock Text="◷   今日" /><TextBlock HorizontalAlignment="Right" Text="{x:Bind TodayCount, Mode=OneWay}" /></Grid>
                        </Button>
                        <Button Click="WeekStories_Click" Style="{StaticResource SideButtonStyle}">
                            <Grid><TextBlock Text="7   過去7日" /><TextBlock HorizontalAlignment="Right" Text="{x:Bind WeekCount, Mode=OneWay}" /></Grid>
                        </Button>
                        <Button Click="FailedSources_Click" Style="{StaticResource SideButtonStyle}">
                            <Grid><TextBlock Text="!   失敗中のサイト" /><TextBlock HorizontalAlignment="Right" Text="{x:Bind FailedSourceCount, Mode=OneWay}" /></Grid>
                        </Button>
                        <Button Click="NotifiedStories_Click" Style="{StaticResource SideButtonStyle}" Content="※   通知済み" />
                        <Button Click="MutedSources_Click" Style="{StaticResource SideButtonStyle}" Content="-   ミュート中" />
                        <Grid Margin="9,24,4,5">
                            <TextBlock CharacterSpacing="190" FontSize="9" FontWeight="SemiBold" Foreground="#9DA39E" Text="SOURCES" />
                            <Button HorizontalAlignment="Right" Click="AddSource_Click" Background="Transparent" BorderThickness="0" Foreground="#718079" Style="{StaticResource TideButtonStyle}" Content="＋" />
                        </Grid>
                        <Button Click="AllSources_Click" Style="{StaticResource SideButtonStyle}" Tag="all">
                            <TextBlock Text="▦   すべてのサイト" />
                        </Button>
                    </StackPanel>
                    <ListView Grid.Row="1" Margin="0,4,0,0" ItemContainerStyle="{StaticResource TideListViewItemStyle}" ItemsSource="{x:Bind SourceRows, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:SourceRowViewModel">
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="26" />
                                    </Grid.ColumnDefinitions>
                                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Click="Source_Click" Style="{StaticResource SideButtonStyle}" Tag="{x:Bind Id}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="21" Height="21" CornerRadius="6" Background="{x:Bind AccentBrush}">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="SemiBold" Foreground="White" Text="{x:Bind Initial}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" TextTrimming="CharacterEllipsis" Text="{x:Bind Title}" />
                                                <TextBlock FontSize="9" Foreground="#A36F62" TextTrimming="CharacterEllipsis" Text="{x:Bind StatusText}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="10" Foreground="#8E978F" Text="{x:Bind UnreadCount}" />
                                        </Grid>
                                    </Button>
                                    <Button Grid.Column="1" AutomationProperties.Name="{x:Bind RemoveAutomationName}" Click="RemoveSource_Click" Background="Transparent" BorderThickness="0" Foreground="#AA8178" Style="{StaticResource TideButtonStyle}" Tag="{x:Bind Id}" Content="×" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="2" Margin="0,10,0,0" Spacing="3">
                        <Button Click="SourceManager_Click" Style="{StaticResource SideButtonStyle}" Content="▤  Source管理" />
                        <Button Click="Settings_Click" Style="{StaticResource SideButtonStyle}" Content="⚙  環境設定" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Padding="38,34,38,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="62" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock CharacterSpacing="190" FontSize="9" FontWeight="SemiBold" Foreground="#9DA39E" Text="{x:Bind PageEyebrow, Mode=OneWay}" />
                        <TextBlock Margin="0,6,0,0" FontFamily="Georgia" FontSize="38" Foreground="#33433B" Text="{x:Bind PageTitle, Mode=OneWay}" />
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#9DA39E" Text="{x:Bind TodayText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="9">
                        <TextBox x:Name="SearchBox" Width="190" Height="38" TextChanged="SearchBox_TextChanged" PlaceholderText="記事を検索" />
                        <Button x:Name="RefreshButton" AutomationProperties.Name="更新" Click="Refresh_Click" Style="{StaticResource QuietButtonStyle}" Content="↻  更新" />
                        <Button AutomationProperties.Name="サイトを追加" Click="AddSource_Click" Style="{StaticResource PrimaryButtonStyle}" Content="＋  サイトを追加" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="9">
                        <TextBlock CharacterSpacing="140" FontSize="10" FontWeight="SemiBold" Foreground="#9CA49F" Text="{x:Bind StoriesCaption, Mode=OneWay}" />
                        <TextBlock CharacterSpacing="140" FontSize="10" FontWeight="SemiBold" Foreground="#CE846E" Text="{x:Bind UnreadCaption, Mode=OneWay}" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Click="MarkAllRead_Click" Background="Transparent" BorderThickness="0" Foreground="#849089" Style="{StaticResource TideButtonStyle}" Content="✓✓  すべて既読にする" />
                </Grid>
                <Grid Grid.Row="2">
                    <ListView ItemContainerStyle="{StaticResource StoryListViewItemStyle}" ItemsSource="{x:Bind StoryCards, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:StoryCardViewModel">
                                <Border MinHeight="190" Padding="0" Background="White" BorderBrush="#E9EDE7" BorderThickness="1" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Background="{x:Bind AccentBrush}">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Georgia" FontSize="64" Foreground="#99FFFFFF" Text="{x:Bind Initial}" />
                                        </Grid>
                                        <Grid Grid.Column="1" Margin="22,18,18,14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <Border Width="21" Height="21" CornerRadius="6" Background="{x:Bind AccentBrush}">
                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8" FontWeight="SemiBold" Foreground="White" Text="{x:Bind Initial}" />
                                                </Border>
                                                <TextBlock VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#75827B" Text="{x:Bind SourceTitle}" />
                                                <TextBlock VerticalAlignment="Center" FontSize="10" Foreground="#C8CCC8" Text="·" />
                                                <TextBlock VerticalAlignment="Center" FontSize="10" Foreground="#9BA39E" Text="{x:Bind RelativeTime}" />
                                                <TextBlock VerticalAlignment="Center" FontSize="10" Foreground="#9BA39E" Text="{x:Bind DiscoveredText}" />
                                                <TextBlock VerticalAlignment="Center" CharacterSpacing="130" FontSize="8" FontWeight="SemiBold" Foreground="#C97E67" Text="{x:Bind NewLabel}" />
                                            </StackPanel>
                                            <Button Grid.Row="1" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Click="OpenStory_Click" Background="Transparent" BorderThickness="0" Padding="0" Style="{StaticResource TideButtonStyle}" Tag="{x:Bind Id}">
                                                <TextBlock Margin="0,11,0,7" FontFamily="Georgia" FontSize="24" Foreground="#3E4944" TextWrapping="Wrap" Text="{x:Bind Title}" />
                                            </Button>
                                            <TextBlock Grid.Row="2" MaxLines="3" FontSize="11" Foreground="#88918C" LineHeight="18" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Text="{x:Bind Summary}" />
                                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                                <TextBlock VerticalAlignment="Center" FontSize="10" Foreground="#B0B5B2" Text="{x:Bind Host}" />
                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="5">
                                                    <Button AutomationProperties.Name="{x:Bind ReadAutomationName}" Click="ToggleRead_Click" Background="Transparent" BorderThickness="0" Foreground="#617B6E" Style="{StaticResource TideButtonStyle}" Tag="{x:Bind Id}" Content="{x:Bind ReadGlyph}" />
                                                    <Button AutomationProperties.Name="{x:Bind SaveAutomationName}" Click="ToggleSaved_Click" Background="Transparent" BorderThickness="0" Foreground="#617B6E" Style="{StaticResource TideButtonStyle}" Tag="{x:Bind Id}" Content="{x:Bind SaveGlyph}" />
                                                    <Button AutomationProperties.Name="ブラウザで開く" Click="OpenStory_Click" Background="Transparent" BorderThickness="0" Foreground="#617B6E" Style="{StaticResource TideButtonStyle}" Tag="{x:Bind Id}" Content="↗" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <Border Width="82" Height="82" HorizontalAlignment="Center" BorderBrush="#D6DED8" BorderThickness="1" CornerRadius="41">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36" Foreground="#80988B" Text="◎" />
                        </Border>
                        <TextBlock Margin="0,18,0,0" HorizontalAlignment="Center" CharacterSpacing="190" FontSize="9" FontWeight="SemiBold" Foreground="#9DA39E" Text="{x:Bind EmptyEyebrow, Mode=OneWay}" />
                        <TextBlock Margin="0,11,0,0" HorizontalAlignment="Center" FontFamily="Georgia" FontSize="31" Foreground="#425149" TextAlignment="Center" Text="{x:Bind EmptyTitle, Mode=OneWay}" />
                        <TextBlock Width="380" Margin="0,9,0,18" FontSize="12" Foreground="#929C96" LineHeight="20" TextAlignment="Center" TextWrapping="Wrap" Text="{x:Bind EmptyMessage, Mode=OneWay}" />
                        <Button HorizontalAlignment="Center" Click="AddSource_Click" Style="{StaticResource PrimaryButtonStyle}" Content="＋  最初のサイトを追加" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Column="2" Padding="20,34,20,20" Background="#F2F2ED" BorderBrush="#E0E4DE" BorderThickness="1,0,0,0">
                <StackPanel>
                    <TextBlock CharacterSpacing="190" FontSize="9" FontWeight="SemiBold" Foreground="#9DA39E" Text="TODAY" />
                    <TextBlock Margin="0,20,0,0" FontFamily="Georgia" FontSize="70" Foreground="#52665B" Text="{x:Bind UnreadPadded, Mode=OneWay}" />
                    <TextBlock Margin="0,5,0,0" FontSize="12" Foreground="#7D8882" LineHeight="20" Text="まだ読んでいない&#x0a;小さな発見があります。" />
                    <Border Height="1" Margin="0,22,0,15" Background="#E0E3DE" />
                    <Grid Margin="0,5"><TextBlock FontSize="11" Foreground="#929A95" Text="ウォッチ中" /><TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="#617068" Text="{x:Bind WatchCount, Mode=OneWay}" /></Grid>
                    <Grid Margin="0,5"><TextBlock FontSize="11" Foreground="#929A95" Text="保存した記事" /><TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="#617068" Text="{x:Bind SavedCount, Mode=OneWay}" /></Grid>
                    <Grid Margin="0,5"><TextBlock FontSize="11" Foreground="#929A95" Text="失敗中" /><TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="#A36F62" Text="{x:Bind FailedSourceCount, Mode=OneWay}" /></Grid>
                    <Grid Margin="0,5"><TextBlock FontSize="11" Foreground="#929A95" Text="次回更新" /><TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="#617068" Text="{x:Bind NextRefreshText, Mode=OneWay}" /></Grid>
                    <Border Margin="0,22,0,0" Padding="12" Background="#E8ECE6" CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontSize="15" Foreground="#D08B73" Text="✦" />
                            <TextBlock Margin="0,6,0,0" FontSize="10" Foreground="#829088" LineHeight="16" TextWrapping="Wrap" Text="{x:Bind RadarStatusText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Button Margin="0,10,0,0" Click="Refresh_Click" Background="Transparent" BorderThickness="0" Foreground="#77857E" Style="{StaticResource TideButtonStyle}" Content="↻  今すぐチェック" />
                </StackPanel>
            </Border>
        </Grid>

        <InfoBar x:Name="StatusBar" Grid.Row="1" Margin="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" IsClosable="True" IsOpen="False" />
    </Grid>
</Window>
